{
  "name": "openclaw-task-watchdog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Task Health watchdog plugin for OpenClaw tasks",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "oxfmt \"src/**/*.ts\" \"tests/**/*.ts\" \"index.ts\"",
    "format:check": "oxfmt --check \"src/**/*.ts\" \"tests/**/*.ts\" \"index.ts\"",
    "lint": "pnpm run format:check && pnpm run typecheck"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "@types/nodemailer": "^8.0.0",
    "@types/react": "^19.2.14",
    "oxfmt": "^0.43.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "packageManager": "pnpm@10.17.0",
  "dependencies": {
    "@react-email/render": "^2.0.5",
    "@sinclair/typebox": "^0.34.49",
    "nodemailer": "^8.0.4",
    "openclaw": "^2026.4.14",
    "react": "^19.2.4",
    "resend": "^6.10.0",
    "zod": "^4.3.6"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "compat": {
      "pluginApi": ">=2026.4.2",
      "minGatewayVersion": "2026.4.2"
    },
    "build": {
      "openclawVersion": "2026.4.2",
      "pluginSdkVersion": "2026.4.2"
    }
  }
}
